{
  "expo": {
    "name": "panotes",
    "slug": "panotes",
    "scheme": "panotes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.panotes.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0A1E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.panotes.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "Allow panotes to access your microphone for voice notes."
        }
      ]
    ]
  }
}
