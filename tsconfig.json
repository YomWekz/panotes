{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./components/*"],
      "@lib/*": ["./lib/*"],
      "@constants/*": ["./constants/*"],
      "@context/*": ["./context/*"]
    }
  },
  "exclude": ["node_modules", "supabase/functions"]
}
